# React Router (single-page app): send unknown paths to index.html.
# API routes map to PHP endpoints for Hostinger/Apache shared hosting.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  RewriteRule ^api/visit/?$ api/visit.php [L]
  RewriteRule ^api/visits/?$ api/visits.php [L]
  RewriteRule ^index\.html$ - [L]

  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  RewriteRule . /index.html [L]
</IfModule>
